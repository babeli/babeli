{
  "name": "babeli",
  "version": "1.0.0-alpha",
  "license": "MIT",
  "scripts": {
    "build": "razzle build",
    "clean": "rimraf build",
    "db:migrate": "NODE_ENV=development sequelize db:migrate && NODE_ENV=test sequelize db:migrate",
    "start:prod": "NODE_ENV=production node build/server.js",
    "start": "razzle start",
    "test:coverage": "razzle test --env=jsdom --coverage --forceExit",
    "test:update": "razzle test --env=jsdom --updateSnapshot --forceExit",
    "test": "razzle test --env=jsdom",
    "pg:create": "docker stop babeli-postgres || true && docker rm babeli-postgres || true && cd docker/postgres && make && docker run --name babeli-postgres -p 5433:5432 -e POSTGRES_USER=babeli -e POSTGRES_PASSWORD=babeli -d --restart=always babeli/postgres"
  },
  "dependencies": {
    "@material-ui/core": "^1.2.1",
    "@material-ui/icons": "^1.1.0",
    "babel-core": "^6.26.3",
    "babel-eslint": "^8.2.3",
    "babel-plugin-add-module-exports": "^0.2.1",
    "babel-plugin-static-fs": "^1.1.0",
    "babel-plugin-transform-async-functions": "^6.22.0",
    "babel-plugin-transform-builtin-extend": "^1.1.2",
    "babel-plugin-transform-decorators-legacy": "^1.3.4",
    "babel-plugin-transform-es2015-modules-commonjs": "^6.26.2",
    "babel-plugin-transform-regenerator": "^6.26.0",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-preset-env": "^1.7.0",
    "babel-preset-stage-0": "^6.24.1",
    "bcrypt": "^2.0.1",
    "boom": "^7.2.0",
    "eslint": "^4.19.1",
    "eslint-config-airbnb-base": "^12.1.0",
    "eslint-plugin-import": "^2.12.0",
    "eslint-plugin-react": "^7.9.1",
    "express": "^4.16.3",
    "hapi": "^17.5.1",
    "hapi-auth-cookie": "^9.0.0",
    "hat": "^0.0.3",
    "inert": "^5.1.0",
    "joi": "^13.4.0",
    "pg": "^7.4.3",
    "pg-hstore": "^2.3.2",
    "prop-types": "^15.6.1",
    "razzle": "^2.1.0",
    "react": "^16.4.0",
    "react-dom": "^16.4.0",
    "react-router-dom": "^4.3.1",
    "sequelize": "^4.37.10",
    "sequelize-cli": "^4.0.0",
    "sqlite3": "^4.0.0",
    "underscore": "^1.9.1",
    "uuid": "^3.2.1",
    "winston": "^3.0.0"
  },
  "devDependencies": {
    "factory-girl": "^5.0.2",
    "faker": "^4.1.0",
    "identity-obj-proxy": "^3.0.0",
    "react-test-renderer": "^16.4.0",
    "rimraf": "^2.6.2"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/server/migrations/*",
      "!src/server/config/*",
      "!src/test/*"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/src/test/__mocks__/fileMock.js",
      "\\.(css|less)$": "<rootDir>/src/test/__mocks__/styleMock.js"
    },
    "setupFiles": [
      "raf/polyfill",
      "./src/test/global.js"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    }
  }
}
